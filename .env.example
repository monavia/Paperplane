# === DISCORD ===
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here
PREFIX=-
TRIGGER=seryn

# === LAVALINK (Main) ===
LAVALINK_HOST=localhost
LAVALINK_PORT=2323
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# === LAVALINK (Backup) — uncomment when additional Lavalink instances are running ===
# LAVALINK_HOST_2=localhost
# LAVALINK_PORT_2=2324
# LAVALINK_PASSWORD_2=youshallnotpass
# LAVALINK_SECURE_2=false

# LAVALINK_HOST_3=localhost
# LAVALINK_PORT_3=2325
