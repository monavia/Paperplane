# === AI (Ollama) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# === DATABASE ===
DATABASE_URI=your_mongodb_connection_string_here

# === DASHBOARD ===
# DASHBOARD_ENABLED=true
# DASHBOARD_PORT=3000
# DASHBOARD_URL=http://localhost:3000
DASHBOARD_CLIENT_SECRET=your_oauth2_client_secret_here
SESSION_SECRET=change_me_to_random_string

# === MUSIC DEFAULTS ===
DEFAULT_VOLUME=80
MAX_QUEUE_SIZE=500
